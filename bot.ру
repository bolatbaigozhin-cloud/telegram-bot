user_data = {}

def get_school_keyboard():
    builder = InlineKeyboardBuilder()
    for school in SCHOOLS.keys():
        builder.button(text=school, callback_data=f"school_{school}")
    builder.adjust(2)
    return builder.as_markup()

def get_subject_keyboard(school):
    builder = InlineKeyboardBuilder()
    for subject in SCHOOLS[school].keys():
        builder.button(text=subject, callback_data=f"subject_{school}_{subject}")
    builder.adjust(2)
    return builder.as_markup()

def get_restart_keyboard():
    builder = InlineKeyboardBuilder()
    builder.button(text="🔄 Пройти снова", callback_data="restart")
    return builder.as_markup()

@dp.message(Command("start"))
async def start(message: types.Message):
    await message.answer("Выбери школу:", reply_markup=get_school_keyboard())

@dp.callback_query(F.data == "restart")
async def restart(callback: types.CallbackQuery):
    await callback.message.answer("Выбери школу:", reply_markup=get_school_keyboard())
    await callback.answer()

@dp.callback_query(F.data.startswith("school_"))
async def pick_school(callback: types.CallbackQuery):
    school = callback.data.split("_")[1]
    await callback.message.answer(f"Школа: {school}\nВыбери предмет:", reply_markup=get_subject_keyboard(school))
    await callback.answer()

@dp.callback_query(F.data.startswith("subject_"))
async def pick_subject(callback: types.CallbackQuery):
    _, school, subject = callback.data.split("_", 2)
    q_list = random.sample(SCHOOLS[school][subject], 5)
    scoring = SCORING[school]
    user_data[callback.from_user.id] = {
        "q_list": q_list,
        "q_num": 0,
        "score": 0,
        "school": school,
        "subject": subject,
        "scoring": scoring,
        "answers": []
    }
    await callback.message.answer(
        f"{school} → {subject}\nПоехали! Всего 5 задач.\n"
        f"Баллы: +{scoring['correct']} за правильный, {scoring['wrong']} за неправильный. Макс: {scoring['max']}"
    )
    q = q_list[0]
    await callback.message.answer(f"Задача 1: {q['q']}")
    await callback.answer()

@dp.message()
async def answer(message: types.Message):
    uid = message.from_user.id
    if uid not in user_data:
        return
    data = user_data[uid]
    q_num = data["q_num"]
    q = data["q_list"][q_num]
    scoring = data["scoring"]

    is_correct = message.text.strip().lower() == q["a"].lower()
    if is_correct:
        data["score"] += scoring["correct"]
        await message.answer(f"✅ Верно! +{scoring['correct']} балл")
    else:
        data["score"] += scoring["wrong"]
        await message.answer(
            f"❌ Неверно. {scoring['wrong']} балл\n"
            f"Правильно: {q['a']}\n\nОбъяснение: {q['explain']}"
        )

    data["answers"].append({
        "q": q["q"],
        "your": message.text,
        "correct": q["a"],
        "ok": is_correct
    })

    data["q_num"] += 1
    if data["q_num"] >= 5:
        # Балл не может быть ниже 0
        final_score = max(0, round(data["score"], 2))
        report = (
            f"🎯 Тест завершен!\n{data['school']} → {data['subject']}\n"
            f"Итоговый балл: {final_score}/{data['scoring']['max']}\n📝 Разбор:\n"
        )
        for i, ans in enumerate(data["answers"], 1):
            status = "✅" if ans["ok"] else "❌"
            report += f"{i}. {status} Твой ответ: {ans['your']}\n"
            if not ans["ok"]:
                report += f" Правильно: {ans['correct']}\n"
        await message.answer(report, reply_markup=get_restart_keyboard())
        del user_data[uid]
    else:
        q = data["q_list"][data["q_num"]]
        await message.answer(f"Задача {data['q_num']+1}: {q['q']}")

